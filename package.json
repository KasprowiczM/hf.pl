{
  "name": "hf-pl",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "check": "npm run lint && npm run build",
    "audit": "npm audit --audit-level=high",
    "ci": "npm run lint && npm run test -- --run && npm run build && npm run audit",
    "test": "vitest",
    "test:watch": "vitest watch",
    "test:coverage": "vitest run --coverage",
    "cf:whoami": "wrangler whoami",
    "deploy:pages": "npm run build && wrangler pages deploy dist",
    "deploy:worker": "npm run build && wrangler deploy"
  },
  "engines": {
    "node": "^22.16.0 || >=24.0.0"
  },
  "overrides": {
    "flatted": "^3.4.2"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "i18next": "^25.10.2",
    "lucide-react": "^0.577.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-helmet-async": "^3.0.0",
    "react-i18next": "^16.6.0",
    "tailwindcss": "^4.2.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "jsdom": "^29.0.1",
    "rollup-plugin-visualizer": "^7.0.1",
    "vite": "^8.0.3",
    "vite-plugin-bundle-analyzer": "^0.0.1",
    "vite-plugin-static-copy": "^4.0.0",
    "vitest": "^4.1.1",
    "wrangler": "^4.76.0"
  }
}
